# ============================================================
# UIG Property Acquisition Pipeline — Environment Variables
# ============================================================
# Copy this file to .env and fill in all values before running.

# --- Database ---
DATABASE_URL=postgresql://uig:uigpassword@localhost:5432/uig_pipeline

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Anthropic AI (Claude) ---
ANTHROPIC_API_KEY=

# --- Twilio WhatsApp API ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- SendGrid Email ---
SENDGRID_API_KEY=
OUTREACH_FROM_EMAIL=philip.george@uigllc.org
OUTREACH_FROM_NAME=Philip George

# --- HubSpot CRM ---
HUBSPOT_API_KEY=
HUBSPOT_PORTAL_ID=

# --- Google Drive (Service Account JSON as single-line string) ---
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=

# --- Apify (optional — enhanced scraping) ---
APIFY_API_TOKEN=

# --- App ---
SECRET_KEY=change-me-to-a-secure-random-string
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000

# --- Sender Identity ---
SENDER_NAME=Philip George
SENDER_TITLE=Property Acquisition Manager, Head of Asia Pacific
SENDER_COMPANY=United Investing Group LLC
SENDER_WEBSITE=https://www.uigllc.org


# --- Make.com Automation ---
MAKE_WEBHOOK_URL=
MAKE_FOLLOWUP_SCENARIO_ID=
UIG_INTERNAL_API_KEY=change-me-internal-api-key
